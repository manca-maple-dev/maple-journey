{
  "$schema": "https://raw.githubusercontent.com/microsoft/pyright/main/packages/pyright/schema/pyrightconfig.schema.json",
  "include": [
    "backend"
  ],
  "exclude": [
    "**/__pycache__",
    "**/.pytest_cache",
    "backend/venv"
  ],
  "executionEnvironments": [
    {
      "root": "backend",
      "extraPaths": [
        "./backend"
      ]
    }
  ],
  "typeCheckingMode": "basic"
}
