MONGO_URL="mongodb://localhost:27017"
DB_NAME="maplejourney"
CORS_ORIGINS="*"
JWT_SECRET="change-me-to-a-long-random-string"
ADMIN_EMAIL="admin@maplejourney.ca"
ADMIN_PASSWORD="change-me"
EMERGENT_LLM_KEY="your-emergent-llm-key"
JOOBLE_API_KEY="your-jooble-api-key"

# Payments - Stripe
# STRIPE_API_KEY=
# STRIPE_WEBHOOK_SECRET=

# Payments - Paystack (African markets)
# PAYSTACK_SECRET_KEY="your-paystack-secret-key"
# PAYSTACK_PUBLIC_KEY="your-paystack-public-key"

# App URLs
# PUBLIC_APP_URL=https://maple-journey-app.vercel.app
# FRONTEND_APP_URL=https://maple-journey-app.vercel.app

# Email - SMTP
# SMTP_HOST=mail.example.com
# SMTP_PORT=465
# SMTP_USERNAME=support@example.com
# SMTP_PASSWORD=your-smtp-password
# SMTP_USE_TLS=true
# SMTP_STARTTLS=false
# SMTP_FROM_EMAIL=support@example.com
# SMTP_FROM_NAME=MapleJourney
# SMTP_REPLY_TO=support@example.com
# SMTP_TIMEOUT=20

# Optional — phone OTP + WhatsApp companion (leave unset to disable those features)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_VERIFY_SERVICE_SID=
# TWILIO_PHONE_NUMBER=
# TWILIO_WHATSAPP_FROM=
# WEBHOOK_BASE_URL=
